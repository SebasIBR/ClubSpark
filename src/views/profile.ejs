
    <%-include('./header')%>
    <section class="contenedorUser">
        <article class="contenedorImagenPerfil">
            <div>Imagen de Perfil</div>
            <img src="../../public/img/profile/<%=userData.image%>" width="200px">
        </article>
        <% if(userData.type==="1"){%>
            <article>
                <section class="bienvenida">
                    <h1>Bienvenido Administrador</h1>
                </section>
                <section>
                    <a href="/admin">
                        <input type="submit" value="Centro de Administracion">
                    </a>
                </section>
            </article>
            <%}%>
        <article class="itemGeneral">
            <div class="itemuser">
                <div>Nombre de Usuario: <%=userData.username%> </div>
            </div>
            <div class="itemuser">
                <div>Correo: <%=userData.email%> </div>
            </div>
            <div class="itemuser">
                <a href="/publication/create">
                    <input type="submit" value="Crear Publicacion" >
                </a>
            </div>
            <div class="itemuser">
                <a href="/profile/edit/<%=userData.id%>">
                    <input type="submit" value="Cambiar Contraseña" >
                </a>
            </div>
        </article>
    </section>
    <%-include('./footer')%>